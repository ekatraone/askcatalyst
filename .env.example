# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB_NAME=askcatalyst

# OpenAI Configuration (for RAG Bot)
OPENAI_API_KEY=your_openai_api_key_here

# Anthropic Configuration (alternative for RAG Bot)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# WATI Configuration
WATI_API_KEY=your_wati_api_key_here
WATI_ENDPOINT=https://api.wati.io

# Application Settings
FLASK_ENV=development
FLASK_DEBUG=True
SECRET_KEY=your_secret_key_here

# RAG Bot Settings (Azure-based)
AZURE_OPENAI_API_KEY=your_azure_openai_api_key
AZURE_OPENAI_ENDPOINT=https://your-resource-name.openai.azure.com/
AZURE_OPENAI_API_VERSION=2024-05-01-preview
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4o
AZURE_OPENAI_ASSISTANT_ID=  # Auto-generated on first run
AZURE_OPENAI_VECTOR_STORE_ID=  # Auto-generated on first run

# Cosmos DB Configuration
COSMOS_DB_ENDPOINT=https://your-account.documents.azure.com:443/
COSMOS_DB_KEY=your_cosmos_db_key
COSMOS_DB_DATABASE=askcatalyst

# WhatsApp Cloud API Configuration
WHATSAPP_ACCESS_TOKEN=your_whatsapp_access_token
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
WHATSAPP_BUSINESS_ACCOUNT_ID=your_business_account_id
WHATSAPP_VERIFY_TOKEN=askcatalyst_verify_token
WHATSAPP_APP_SECRET=your_app_secret
WHATSAPP_API_VERSION=v18.0
