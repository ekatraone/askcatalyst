# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB_NAME=askcatalyst

# OpenAI Configuration (for RAG Bot)
OPENAI_API_KEY=your_openai_api_key_here

# Anthropic Configuration (alternative for RAG Bot)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# WATI Configuration
WATI_API_KEY=your_wati_api_key_here
WATI_ENDPOINT=https://api.wati.io

# Application Settings
FLASK_ENV=development
FLASK_DEBUG=True
SECRET_KEY=your_secret_key_here

# RAG Bot Settings
RAG_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
RAG_LLM_MODEL=gpt-3.5-turbo
RAG_CHUNK_SIZE=500
RAG_CHUNK_OVERLAP=50
RAG_TOP_K=5
RAG_SIMILARITY_THRESHOLD=0.7
RAG_VECTOR_STORE_TYPE=faiss
